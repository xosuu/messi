<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android" android:opacity="opaque">
    <item>
        <shape>
            <gradient
                android:startColor="@color/bd"
                android:endColor="@color/be"
                android:angle="90"
                android:centerColor="@color/be"/>
        </shape>
    </item>
    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/g7"
            android:tileMode="disabled"/>
    </item>
    <item android:top="85dp">
        <bitmap
            android:gravity="center"
            android:src="@drawable/ey"
            android:tileMode="disabled"/>
    </item>
</layer-list>
