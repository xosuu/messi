<?xml version="1.0" encoding="utf-8"?>
<animated-selector xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <item
        android:state_checked="true"
        android:id="@+id/f2"
        android:drawable="@drawable/hi"/>
    <item
        android:id="@+id/kv"
        android:drawable="@drawable/hi"
        app:state_indeterminate="true"/>
    <item
        android:state_checked="false"
        android:id="@+id/y0"
        android:drawable="@drawable/hj"/>
    <transition
        android:drawable="@drawable/h4"
        android:toId="@+id/y0"
        android:fromId="@+id/f2"/>
    <transition
        android:drawable="@drawable/hb"
        android:toId="@+id/f2"
        android:fromId="@+id/y0"/>
    <transition
        android:drawable="@drawable/h4"
        android:toId="@+id/y0"
        android:fromId="@+id/kv"/>
    <transition
        android:drawable="@drawable/hb"
        android:toId="@+id/kv"
        android:fromId="@+id/y0"/>
</animated-selector>
