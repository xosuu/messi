        android:drawable="@drawable/hu"
        android:toId="@+id/f2"
        android:fromId="@+id/r5"/>
    <transition
        android:drawable="@drawable/hu"
        android:toId="@+id/yu"
        android:fromId="@+id/r5"/>
    <transition
        android:drawable="@drawable/hv"
        android:toId="@+id/y0"
        android:fromId="@+id/r5"/>
    <transition
        android:drawable="@drawable/hr"
        android:toId="@+id/r5"
        android:fromId="@+id/f2"/>
    <transition
        android:drawable="@drawable/hs"
        android:toId="@+id/y0"
        android:fromId="@+id/f2"/>
    <transition
        android:drawable="@drawable/hr"
        android:toId="@+id/r5"
        android:fromId="@+id/yu"/>
    <transition
        android:drawable="@drawable/hy"
        android:toId="@+id/r5"
        android:fromId="@+id/y0"/>
