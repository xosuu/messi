            android:paddingLeft="@dimen/u4"
            android:paddingTop="@dimen/nm"
            android:paddingBottom="@dimen/nm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:layout_weight="2">
            <com.codetroopers.betterpickers.widget.ZeroTopPaddingTextView
                android:ellipsize="none"
                android:id="@+id/kf"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                style="@style/a40"/>
            <com.codetroopers.betterpickers.widget.ZeroTopPaddingTextView
                android:ellipsize="none"
                android:id="@+id/kd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                style="@style/a40"/>
            <com.codetroopers.betterpickers.widget.ZeroTopPaddingTextView
                android:ellipsize="none"
                android:id="@+id/ke"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/yd"
                android:singleLine="true"
                style="@style/a43"/>
            <com.codetroopers.betterpickers.widget.ZeroTopPaddingTextView
                android:ellipsize="none"
                android:id="@+id/nz"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                style="@style/a40"/>
            <com.codetroopers.betterpickers.widget.ZeroTopPaddingTextView
                android:ellipsize="none"
                android:id="@+id/nx"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                style="@style/a40"/>
            <com.codetroopers.betterpickers.widget.ZeroTopPaddingTextView
                android:ellipsize="none"
                android:gravity="top"
                android:id="@+id/cc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/yc"
                android:singleLine="true"
                style="@style/a3z"/>
        </com.codetroopers.betterpickers.timepicker.TimerView>
        <ImageButton
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/gz"
            android:background="@drawable/g_"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:src="@drawable/e_"
            android:contentDescription="@string/yh"/>
    </LinearLayout>
    <View
        android:id="@+id/hh"
        android:background="@color/c1"
        android:layout_width="match_parent"
        android:layout_height="1dp"/>
    <include
        android:id="@+id/j_"
        layout="@layout/ek"/>
    <include
        android:id="@+id/t3"
        layout="@layout/ek"/>
    <include
        android:id="@+id/wm"
        layout="@layout/ek"/>
    <include
        android:id="@+id/jk"
        layout="@layout/el"/>
</LinearLayout>
