<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.view.menu.ListMenuItemView xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minWidth="196dp">
    <ImageView
        android:id="@+id/jv"
        android:background="@drawable/bc"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"/>
    <LinearLayout
        android:id="@+id/fx"
        android:duplicateParentState="true"
        android:layout_width="match_parent"
        android:layout_height="?attr/kj"
        style="@style/ih">
        <RelativeLayout
            android:layout_gravity="center_vertical"
            android:duplicateParentState="true"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/ii">
            <TextView
                android:textAppearance="?attr/a4i"
                android:ellipsize="marquee"
                android:id="@+id/x0"
                android:fadingEdge="horizontal"
                android:duplicateParentState="true"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:layout_alignParentTop="true"
                style="@style/il"/>
            <TextView
                android:textAppearance="?attr/a4r"
                android:id="@+id/tj"
                android:duplicateParentState="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:layout_below="@+id/x0"
                style="@style/il"/>
        </RelativeLayout>
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/uy"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scaleType="center"
            style="@style/ik"/>
    </LinearLayout>
</androidx.appcompat.view.menu.ListMenuItemView>
