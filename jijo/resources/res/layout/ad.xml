                            android:gravity="start|top"
                            android:id="@+id/vo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Filename"
                            android:inputType="textMultiLine"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false">
                        <CheckBox
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:gravity="top"
                            android:id="@+id/eu"
                            android:paddingTop="4dp"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Lock All (payload, server, user &amp; proxy)"
                            android:layout_weight="0.5"/>
                        <CheckBox
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:gravity="top"
                            android:id="@+id/ev"
                            android:paddingTop="4dp"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Lock Payload &amp; Unlock Server"
                            android:layout_weight="0.5"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false">
                        <CheckBox
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:gravity="top"
                            android:id="@+id/ew"
                            android:paddingTop="4dp"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Unlock User &amp; Pass"
                            android:layout_weight="0.5"/>
                        <CheckBox
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:gravity="top"
                            android:id="@+id/ey"
                            android:paddingTop="4dp"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Unlock Remote Proxy"
                            android:layout_weight="0.5"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false">
                        <CheckBox
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:id="@+id/er"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Mobile Data"
                            android:layout_weight="0.5"/>
                        <CheckBox
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:id="@+id/ez"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Block Root"
                            android:layout_weight="0.5"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false">
                        <CheckBox
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:id="@+id/et"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="HWID"
                            android:layout_weight="0.5"/>
                        <CheckBox
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:id="@+id/ex"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Note"
                            android:layout_weight="0.5"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false">
                        <CheckBox
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:id="@+id/ea"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Password"
                            android:layout_weight="0.5"/>
                        <CheckBox
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:id="@+id/e_"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Extra Sniffer"
                            android:layout_weight="0.5"/>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/x3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="5dp"
                        android:layout_marginTop="5dp"
                        android:layout_marginRight="5dp"
                        android:text="Extra"/>
                    <View
                        android:id="@+id/b6"
                        android:background="@android:color/darker_gray"
                        android:layout_width="match_parent"
                        android:layout_height="0.1dp"
                        android:layout_marginLeft="5dp"
                        android:layout_marginTop="5dp"
                        android:layout_marginRight="5dp"
                        android:layout_marginBottom="5dp"/>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false">
                        <CheckBox
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:id="@+id/e8"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SSH/VPN with HWID"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false">
                        <CheckBox
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:id="@+id/e9"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
