                            android:id="@+id/eb"
                            android:paddingTop="4dp"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Psiphon Settings"
                            android:layout_weight="0.5"/>
                        <CheckBox
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:gravity="top"
                            android:id="@+id/ec"
                            android:paddingTop="4dp"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Special Version"
                            android:layout_weight="0.5"/>
                    </LinearLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/r4"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <EditText
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:id="@+id/r3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Powered by Nick (Max 20 chars)"
                            android:maxLines="1"
                            android:maxLength="20"
                            android:inputType="text"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/pu"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <EditText
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:id="@+id/pt"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Note (ex. 2020 © ePro Dev. Team)"
                            android:inputType="textMultiLine"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <TextView
                        android:textAppearance="@style/kz"
                        android:textColorLink="@color/b_"
                        android:gravity="start"
                        android:autoLink="web"
                        android:linksClickable="false"
                        android:id="@+id/vx"
                        android:paddingLeft="2dp"
                        android:paddingRight="2dp"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="5dp"
                        android:layout_marginBottom="5dp"
                        android:text="Note (ex. 2020 © ePro Dev. Team)"/>
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/kj"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <EditText
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:id="@+id/ki"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Support multiple HWID (ex. x..;x..)"
                            android:inputType="textMultiLine"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/qq"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <EditText
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:id="@+id/qp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Set password config"
                            android:inputType="textMultiLine"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/y5"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <EditText
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:id="@+id/y4"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Direct link config must already exist"
                            android:inputType="textMultiLine"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/d4"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <EditText
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:id="@+id/d3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Block separated by semicolon (;)"
                            android:inputType="textMultiLine"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp">
                        <Button
                            android:textColor="@android:color/white"
                            android:id="@+id/dr"
                            android:background="@drawable/d1"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_marginLeft="5dp"
                            android:text="Save"
                            android:layout_weight="1"
                            android:textAllCaps="false"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:layout_gravity="center_horizontal"
                    android:orientation="vertical"
                    android:id="@+id/m2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/vw"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <EditText
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:gravity="start|top"
                            android:id="@+id/w2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Server Name Indication"
                            android:inputType="textMultiLine"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp">
                        <Button
                            android:textColor="@android:color/white"
                            android:id="@+id/dn"
                            android:background="@drawable/d1"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_marginLeft="5dp"
                            android:text="Apply"
                            android:layout_weight="1"
                            android:textAllCaps="false"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:layout_gravity="center_horizontal"
                    android:orientation="vertical"
                    android:id="@+id/lo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/vr"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
