                            android:hint="@string/to"
                            android:maxLines="1"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <TextView
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/bf"
                        android:textColorLink="@color/b_"
